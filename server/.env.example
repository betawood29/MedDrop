# Server
PORT=5002
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# JWT — generate a strong secret: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND
JWT_EXPIRE=30d

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WhatsApp notifications (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Admin
ADMIN_PHONE=
ADMIN_PASSWORD=

# Client URL (for CORS in production)
CLIENT_URL=https://your-production-domain.com
